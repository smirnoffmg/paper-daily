# Required
TELEGRAM_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=@your_channel_or_-100xxxxxxxxxx

# Optional — comma-separated search topics
# PAPER_QUERIES=machine learning,deep learning,reinforcement learning

# Optional — filter to specific venues (substring match, case-insensitive)
# PAPER_VENUES=NeurIPS,ICML,ICLR

# Optional — path to your interest profile (one paper title per line)
# PROFILE_PATH=profile.txt

# Optional — skip Telegram post, print formatted message to stdout instead
# DRY_RUN=false

# Optional — email sent in OpenAlex polite-pool User-Agent header
# OPENALEX_EMAIL=smirnoffmg@gmail.com

# Optional — tuning
# CANDIDATES_PER_QUERY=100
# TOP_K=30
# MODEL_NAME=allenai/specter2_base
# ABSTRACT_MAX_CHARS=800
